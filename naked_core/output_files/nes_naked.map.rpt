; Signed Embedded Multipliers           ; 6           ;
; Unsigned Embedded Multipliers         ; 7           ;
; Mixed Sign Embedded Multipliers       ; 4           ;
; Variable Sign Embedded Multipliers    ; 0           ;
; Dedicated Input Shift Register Chains ; 0           ;
+---------------------------------------+-------------+
Note: number of Embedded Multiplier Blocks used is only available after a successful fit.


Encoding Type:  One-Hot
+---------------------------------------------------------------------------------------------+
; State Machine - |top_level|NES:nes|cart_top:multi_mapper|MapperFDS:mapfds|MAPFDS:fds|Rstate ;
+-----------+-----------+-----------+---------------------------------------------------------+
; Name      ; Rstate.00 ; Rstate.10 ; Rstate.01                                               ;
+-----------+-----------+-----------+---------------------------------------------------------+
; Rstate.00 ; 0         ; 0         ; 0                                                       ;
; Rstate.01 ; 1         ; 0         ; 1                                                       ;
; Rstate.10 ; 1         ; 1         ; 0                                                       ;
+-----------+-----------+-----------+---------------------------------------------------------+


Encoding Type:  One-Hot
+---------------------------------------------------------------------------------------------+
; State Machine - |top_level|NES:nes|cart_top:multi_mapper|MapperFDS:mapfds|MAPFDS:fds|Wstate ;
+-----------+-----------+-----------+---------------------------------------------------------+
; Name      ; Wstate.00 ; Wstate.10 ; Wstate.01                                               ;
+-----------+-----------+-----------+---------------------------------------------------------+
; Wstate.00 ; 0         ; 0         ; 0                                                       ;
; Wstate.01 ; 1         ; 0         ; 1                                                       ;
; Wstate.10 ; 1         ; 1         ; 0                                                       ;
+-----------+-----------+-----------+---------------------------------------------------------+


Encoding Type:  One-Hot
+---------------------------------------------------------------------------------------------------------------------------+
; State Machine - |top_level|NES:nes|cart_top:multi_mapper|Mapper16:map16|EEPROM_24C0x:eeprom|state                         ;
