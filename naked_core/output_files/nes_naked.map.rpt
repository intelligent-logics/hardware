+---------------------+-------------------+---------------------+------------------+---------------------+------------------+
; state.STATE_STANDBY ; 0                 ; 0                   ; 0                ; 0                   ; 0                ;
; state.STATE_TEST    ; 0                 ; 0                   ; 1                ; 1                   ; 0                ;
; state.STATE_ADDRESS ; 0                 ; 1                   ; 0                ; 1                   ; 0                ;
; state.STATE_WRITE   ; 1                 ; 0                   ; 0                ; 1                   ; 0                ;
; state.STATE_READ    ; 0                 ; 0                   ; 0                ; 1                   ; 1                ;
+---------------------+-------------------+---------------------+------------------+---------------------+------------------+


